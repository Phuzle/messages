<?xml version="1.0" encoding="utf-8"?>
<!-- Merged only into debug builds — adds the permissive network security config for the local
     Layer 3 dev server, and WRITE_CONTACTS for DebugSimulationReceiver's test-contact-photo
     seeding, without weakening a real release build. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <application android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
